generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts    TrustedContact[]
  occurrences Occurrence[]
  sosAlerts   SOSAlert[]
}

model TrustedContact {
  id        String   @id @default(uuid())
  name      String
  phone     String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

enum OccurrenceType {
  ERROR
  WARNING
}

model Occurrence {
  id          String         @id @default(uuid())
  title       String
  description String
  type        OccurrenceType
  latitude    Float
  longitude   Float
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  createdAt   DateTime       @default(now())
}

model SOSAlert {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
